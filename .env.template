# Soccer Edge Engine — Environment Configuration
# Copy this file to .env and fill in your values.
# The app runs safely with all keys blank — falls back to MOCK mode.
#
# ── Data mode ────────────────────────────────────────────────────────────
# Options:
#   MOCK            — always works, no keys needed (default)
#   KALSHI_PUBLIC   — public REST endpoint, no auth required
#   KALSHI_AUTH_TEST— test RSA auth credentials, then load public data
#   HYBRID          — Kalshi public + mock rows side by side
DATA_MODE=MOCK

# ── Kalshi environment ─────────────────────────────────────────────────────
# prod  = production (default)
# demo  = demo/paper environment
KALSHI_ENV=prod

# Kalshi REST base URLs (change only if Kalshi moves their endpoints)
KALSHI_PROD_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_DEMO_API_BASE=https://demo-api.kalshi.co/trade-api/v2

# ── Kalshi credentials ────────────────────────────────────────────────────
# Only needed for KALSHI_AUTH_TEST mode.
# Get from: https://kalshi.com/profile/api-keys
# KALSHI_API_KEY_ID  = the Key ID string shown on the Kalshi API page
# KALSHI_PRIVATE_KEY_PATH = full path to your downloaded .pem private key file
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# ── Safety switches ────────────────────────────────────────────────────────
# AUTO_TRADING_ENABLED is hardcoded OFF in code. This env var is ignored.
AUTO_TRADING_ENABLED=false

# ── Scanner defaults ───────────────────────────────────────────────────────
MIN_EDGE_CENTS=8
MAX_SPREAD_CENTS=5
MAX_TRADE_SIZE=10
MAX_DAILY_LOSS=30
LIVE_REFRESH_SECONDS=15

# ── Other feeds (optional) ─────────────────────────────────────────────────
ODDS_API_KEY=

# ── API-Football / apisports soccer data ──────────────────────────────────
# Get a free key at: https://www.api-football.com  (direct = apisports)
#                 or https://rapidapi.com/api-sports (via RapidAPI)
#
# PROVIDER SETTING (required for correct headers):
#   apisports  = direct subscription → uses header: x-apisports-key
#   rapidapi   = RapidAPI subscription → uses header: x-rapidapi-key
API_FOOTBALL_PROVIDER=apisports
#
# KEY (app checks these names in order — first non-empty wins):
#   1. API_FOOTBALL_KEY   ← preferred canonical name
#   2. FOOTBALL_API_KEY   ← legacy name (backward compat)
#   3. RAPIDAPI_KEY       ← if you use API-Football via RapidAPI
# Set any ONE of these — you do not need all three.
API_FOOTBALL_KEY=
FOOTBALL_API_KEY=
RAPIDAPI_KEY=
