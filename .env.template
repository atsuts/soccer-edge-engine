# Soccer Edge Engine — Environment Configuration
# Copy this file to .env and fill in your keys.
# The app runs fine with all keys empty (falls back to MOCK mode).

# ── Data mode ────────────────────────────────────────────────────────────
# Options: MOCK | KALSHI_LIVE | HYBRID
DATA_MODE=MOCK

# ── Safety switches ───────────────────────────────────────────────────────
AUTO_TRADING_ENABLED=false
PAPER_MODE=true

# ── Kalshi API ────────────────────────────────────────────────────────────
# Get keys at: https://kalshi.com/api
# Leave blank to stay in MOCK mode.
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_BASE_URL=https://trading-api.kalshi.com/trade-api/v2

# ── The Odds API (soccer odds) ────────────────────────────────────────────
# Get key at: https://the-odds-api.com
ODDS_API_KEY=

# ── API-Football (soccer feed) ────────────────────────────────────────────
FOOTBALL_API_KEY=

# ── Scanner defaults ──────────────────────────────────────────────────────
SCANNER_MIN_EDGE=8
SCANNER_MAX_SPREAD=5
SCANNER_MAX_TRADE_SIZE=10
SCANNER_DAILY_LOSS_LIMIT=30
SCANNER_REFRESH_SECONDS=30
